---
const { title } = Astro.props;
import '../styles/app.css';
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <slot name="head" />
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen">
  <div id="app"></div>
  <slot />
</body>
</html>
