---
import Layout from '../../layouts/Layout.astro';
import CardList from '../../components/CardList.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const tools = await getCollection('tools');
const sortedTools = tools.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const screenshots = import.meta.glob<{ default: import('astro').ImageMetadata }>('../../assets/tools/*.png', { eager: true });

function toolUrl(tool: { id: string; data: { url?: string } }) {
  return tool.data.url || `${base}tools/${tool.id.replace('.json', '')}/`;
}

function screenshot(tool: { id: string }) {
  const key = `../../assets/tools/${tool.id.replace('.json', '')}.png`;
  return screenshots[key]?.default;
}

const items = sortedTools.map(tool => ({
  url: toolUrl(tool),
  title: tool.data.title,
  description: tool.data.description,
  date: tool.data.date,
  image: screenshot(tool),
}));
---

<Layout title="Tools" description="A collection of useful tools">
  <h1>Tools</h1>
  <p>A collection of useful tools mostly created with Claude.</p>

  <CardList items={items} />
</Layout>
