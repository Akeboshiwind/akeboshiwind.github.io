---
import Layout from '../../layouts/Layout.astro';
import CardList from '../../components/CardList.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const works = await getCollection('works');
const sortedWorks = works.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const screenshots = import.meta.glob<{ default: import('astro').ImageMetadata }>('../../assets/tools/*.png', { eager: true });

function workUrl(work: { id: string; data: { url?: string } }) {
  return work.data.url || `${base}tools/${work.id.replace('.json', '')}/`;
}

function screenshot(work: { id: string }) {
  const key = `../../assets/tools/${work.id.replace('.json', '')}.png`;
  return screenshots[key]?.default;
}

const items = sortedWorks.map(work => ({
  url: workUrl(work),
  title: work.data.title,
  description: work.data.description,
  date: work.data.date,
  image: screenshot(work),
}));
---

<Layout title="Works" description="A collection of things I've built">
  <h1 class="text-2xl font-bold text-heading mt-6 mb-2">Works</h1>
  <p class="my-4">A collection of things I've built, mostly with Claude.</p>

  <CardList items={items} />
</Layout>
