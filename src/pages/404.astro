---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found">
  <h1 class="text-2xl font-bold text-heading mt-6 mb-2">404 - Page Not Found</h1>
  <p class="my-4">The page you're looking for doesn't exist.</p>
  <p class="my-4"><a href={import.meta.env.BASE_URL} class="text-link visited:text-link-visited no-underline hover:underline">Go back home</a></p>
</Layout>
