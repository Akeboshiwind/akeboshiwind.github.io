---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');

  return notes.map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---

<Layout
  title={note.data.title}
  description={note.data.title}
  type="article"
  publishedTime={note.data.date}
>
  <article class="prose prose-sm font-sans max-w-none leading-relaxed
    prose-a:text-link prose-a:no-underline hover:prose-a:underline prose-a:visited:text-link-visited
    prose-code:font-mono prose-code:bg-code-bg prose-code:text-code-text prose-code:px-1 prose-code:rounded-sm prose-code:font-normal prose-code:before:content-none prose-code:after:content-none
    prose-pre:font-mono">
    <h1>
      {note.data.title}
    </h1>

    <p>
      <time datetime={note.data.date.toISOString().split('T')[0]} class="font-mono text-[0.9rem]">
        {note.data.date.toISOString().split('T')[0]}
      </time>
    </p>

    <Content />

    {note.data.tags && note.data.tags.length > 0 && (
      <p>
        Tags: {note.data.tags.map((tag, i) => (
          <span>
            {i > 0 && ', '}
            #{tag}
          </span>
        ))}
      </p>
    )}
  </article>
</Layout>
