---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const tools = await getCollection('tools');
const recentTools = tools
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

function toolUrl(tool: { id: string; data: { url?: string } }) {
  return tool.data.url || `${base}tools/${tool.id.replace('.json', '')}/`;
}

function screenshotPath(tool: { id: string }) {
  return `${base}tools/screenshots/${tool.id.replace('.json', '')}.png`;
}
---

<Layout>
  <h1>Welcome</h1>
  <p>
    This site focuses on Clojure, programming, and occasional thoughts about technology.
  </p>

  <h2>Recent Posts</h2>
  <ul class="post-list">
    {recentPosts.map(post => (
      <li>
        <time datetime={post.data.date.toISOString().split('T')[0]}>
          {post.data.date.toISOString().split('T')[0]}
        </time>
        <a href={`${base}blog/${post.slug}/`}>
          {post.data.title}
          {post.data.draft && <span class="draft-marker">[DRAFT]</span>}
        </a>
      </li>
    ))}
  </ul>

  <p><a href={`${base}blog/`}>View all posts &rarr;</a></p>

  <h2>Recent Tools</h2>
  <div class="tool-grid">
    {recentTools.map(tool => (
      <a href={toolUrl(tool)} class="tool-card">
        <img
          src={screenshotPath(tool)}
          alt={`Screenshot of ${tool.data.title}`}
          class="tool-screenshot"
          loading="lazy"
        />
        <div class="tool-info">
          <h2 class="tool-title">{tool.data.title}</h2>
          <p class="tool-description">{tool.data.description}</p>
        </div>
      </a>
    ))}
  </div>

  <p><a href={`${base}tools/`}>View all tools &rarr;</a></p>
</Layout>

<style>
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .tool-card:visited {
    color: inherit;
  }

  .tool-card:hover {
    border-color: var(--link);
    text-decoration: none;
  }

  .tool-screenshot {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top left;
    border-bottom: 1px solid var(--border);
  }

  .tool-info {
    padding: 0.75rem 1rem;
  }

  .tool-title {
    font-size: 1rem;
    margin: 0 0 0.25rem;
    color: var(--link);
  }

  .tool-card:visited .tool-title {
    color: var(--link-visited);
  }

  .tool-description {
    font-size: 0.8rem;
    margin: 0;
    color: var(--text);
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
