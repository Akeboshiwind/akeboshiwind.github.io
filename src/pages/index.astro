---
import Layout from '../layouts/Layout.astro';
import CardList from '../components/CardList.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const notes = await getCollection('notes');
const recentNotes = notes
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const works = await getCollection('works');
const recentWorks = works
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const screenshots = import.meta.glob<{ default: import('astro').ImageMetadata }>('../assets/tools/*.png', { eager: true });

function workUrl(work: { id: string; data: { url?: string } }) {
  return work.data.url || `${base}tools/${work.id.replace('.json', '')}/`;
}

function screenshot(work: { id: string }) {
  const key = `../assets/tools/${work.id.replace('.json', '')}.png`;
  return screenshots[key]?.default;
}

const noteItems = recentNotes.map(note => ({
  url: `${base}${note.slug}/`,
  title: note.data.title,
  date: note.data.date,
}));

const workItems = recentWorks.map(work => ({
  url: workUrl(work),
  title: work.data.title,
  description: work.data.description,
  image: screenshot(work),
}));
---

<Layout>
  <h1 class="text-2xl font-bold text-heading mt-6 mb-2">Welcome</h1>
  <p class="my-4">
    This site focuses on Clojure, programming, and occasional thoughts about technology.
  </p>

  <h2 class="text-xl font-bold text-heading mt-6 mb-2">Recent Notes</h2>
  <CardList items={noteItems} showImages={false} />

  <p class="my-4"><a href={`${base}notes/`} class="text-link visited:text-link-visited no-underline hover:underline">View all notes &rarr;</a></p>

  <h2 class="text-xl font-bold text-heading mt-6 mb-2">Recent Works</h2>
  <CardList items={workItems} />

  <p class="my-4"><a href={`${base}works/`} class="text-link visited:text-link-visited no-underline hover:underline">View all works &rarr;</a></p>
</Layout>
