---
import Layout from '../layouts/Layout.astro';
import CardList from '../components/CardList.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const tools = await getCollection('tools');
const recentTools = tools
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const screenshots = import.meta.glob<{ default: import('astro').ImageMetadata }>('../assets/tools/*.png', { eager: true });

function toolUrl(tool: { id: string; data: { url?: string } }) {
  return tool.data.url || `${base}tools/${tool.id.replace('.json', '')}/`;
}

function screenshot(tool: { id: string }) {
  const key = `../assets/tools/${tool.id.replace('.json', '')}.png`;
  return screenshots[key]?.default;
}

const postItems = recentPosts.map(post => ({
  url: `${base}blog/${post.slug}/`,
  title: post.data.title,
  date: post.data.date,
  draft: post.data.draft,
}));

const toolItems = recentTools.map(tool => ({
  url: toolUrl(tool),
  title: tool.data.title,
  description: tool.data.description,
  image: screenshot(tool),
}));
---

<Layout>
  <h1 class="text-2xl font-bold text-heading mt-6 mb-2">Welcome</h1>
  <p class="my-4">
    This site focuses on Clojure, programming, and occasional thoughts about technology.
  </p>

  <h2 class="text-xl font-bold text-heading mt-6 mb-2">Recent Posts</h2>
  <CardList items={postItems} />

  <p class="my-4"><a href={`${base}blog/`} class="text-link visited:text-link-visited no-underline hover:underline">View all posts &rarr;</a></p>

  <h2 class="text-xl font-bold text-heading mt-6 mb-2">Recent Tools</h2>
  <CardList items={toolItems} />

  <p class="my-4"><a href={`${base}tools/`} class="text-link visited:text-link-visited no-underline hover:underline">View all tools &rarr;</a></p>
</Layout>
