---
import Layout from '../layouts/Layout.astro';
import CardList from '../components/CardList.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const notes = await getCollection('notes');
const works = await getCollection('works');

const screenshots = import.meta.glob<{ default: import('astro').ImageMetadata }>('../assets/works/*.png', { eager: true });

function workUrl(work: { id: string; data: { url?: string } }) {
  return work.data.url || `${base}${work.id.replace('.json', '')}/`;
}

function screenshot(work: { id: string }) {
  const key = `../assets/works/${work.id.replace('.json', '')}.png`;
  return screenshots[key]?.default;
}

const allItems = [
  ...notes.map(note => ({
    url: `${base}${note.slug}/`,
    title: note.data.title,
    stage: note.data.stage,
    date: note.data.updated ?? note.data.date,
    pinned: note.data.pinned,
  })),
  ...works.map(work => ({
    url: workUrl(work),
    title: work.data.title,
    stage: work.data.stage,
    description: work.data.description,
    date: work.data.updated ?? work.data.date,
    image: screenshot(work),
    pinned: work.data.pinned,
  })),
];

const pinned = allItems.filter(i => i.pinned).sort((a, b) => b.date.getTime() - a.date.getTime());
const rest = allItems.filter(i => !i.pinned).sort((a, b) => b.date.getTime() - a.date.getTime());
---

<Layout>
  <a href={`${base}tools/`} class="text-sm text-text opacity-60 hover:opacity-100 no-underline hover:underline">All tools →</a>

  {pinned.length > 0 && (
    <>
      <h2 class="text-sm font-semibold text-heading mt-6 mb-1 uppercase tracking-wide opacity-60">Pinned</h2>
      <CardList items={pinned} />
    </>
  )}

  <h2 class="text-sm font-semibold text-heading mt-6 mb-1 uppercase tracking-wide opacity-60">Recent</h2>
  <CardList items={rest} />
</Layout>
