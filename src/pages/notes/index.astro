---
import Layout from '../../layouts/Layout.astro';
import CardList from '../../components/CardList.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');

const base = import.meta.env.BASE_URL;

const sortedNotes = notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const items = sortedNotes.map(note => ({
  url: `${base}${note.slug}/`,
  title: note.data.title,
  stage: note.data.stage,
  date: note.data.date,
}));
---

<Layout title="Notes" description="All notes">
  <h1 class="text-2xl font-bold text-heading mt-6 mb-2">Notes</h1>

  <CardList items={items} showImages={false} />
</Layout>
