---
// Full-page SPA — no Astro layout
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
  <title>Coffee Merge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;700&family=Caveat:wght@600&display=swap" rel="stylesheet" />
</head>
<body>
  <div id="stage">
    <div id="hud-top">
      <div id="score">Score<b id="scoreVal">0</b></div>
      <div id="next">
        <img id="nextImg" alt="" />
        <span class="label">next</span>
      </div>
    </div>
    <div id="wrap">
      <canvas id="game"></canvas>
      <div id="hint" class="hud">tap to launch ↑</div>
      <div id="gameover">
        <h2>Last Call!</h2>
        <p class="final">final score <span id="finalScore">0</span></p>
        <button id="restart">Pour Again</button>
      </div>
    </div>
  </div>
  <script>
    import './_app/style.css';
    import './_app/game.js';
  </script>
</body>
</html>
