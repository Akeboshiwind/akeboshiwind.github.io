const TABS=[
  {id:"playbook",label:"Playbook"},{id:"johto",label:"Johto Gyms"},{id:"rival",label:"Rival"},
  {id:"e4",label:"Elite Four"},{id:"kanto",label:"Kanto Gyms"},{id:"red",label:"Red"},
  {id:"rocket",label:"Rocket"},{id:"legend",label:"Legendaries"}
];
// Persist UI selections in localStorage, matching the React tools'
// `<slug>_` key convention.
const STORE='heartgold-battle-prep_';
const save=(k,v)=>{try{localStorage.setItem(STORE+k,v);}catch(e){}};
const load=(k,d)=>{try{const v=localStorage.getItem(STORE+k);return v===null?d:v;}catch(e){return d;}};
const STARTERS=['chikorita','cyndaquil','totodile'];
const TAB_IDS=TABS.map(t=>t.id);
let starter=load('starter','cyndaquil'); if(!STARTERS.includes(starter))starter='cyndaquil';
let activeTab=load('tab','playbook'); if(!TAB_IDS.includes(activeTab))activeTab='playbook';

function monRow(m){return `<div class="mon ${m[3]?'ace':''}"><span><span class="nm">${m[0]}</span> <span class="tp">${m[1]}</span></span><span class="ml">Lv ${m[2]}</span></div>`;}
function resolveSlots(slots){
  const L=RIVAL_LINE[starter];
  return slots.map(s=>{let nm=s[0],tp=s[1];
    if(nm==="@base")nm=L.base; if(nm==="@mid")nm=L.mid; if(nm==="@late")nm=L.late;
    if(tp==="@type")tp=L.type; return [nm,tp,s[2],s[3]];});
}
function bossCard(b,prefix){
  const c=TC(b.type);
  const team=(b.team||[]).map(monRow).join("");
  const catches=(b.catches||[]).map(x=>`<div class="chip"><b>${x[0]}</b> — ${x[1]}</div>`).join("");
  return `<div class="card" style="--gc:${c}" open-state="0">
    <button class="chead" aria-expanded="false">
      <div class="stamp"><span class="cap">Cap</span><span class="lv">${b.cap}</span></div>
      <div class="cmeta"><div class="cnum">${prefix}</div><div class="cname">${b.name}</div>
        <div class="badges"><span class="type">${b.type}</span><span class="loc">${b.loc}${b.when?' · '+b.when:''}</span></div></div>
      <span class="chev">&#9654;</span>
    </button>
    <div class="trick"><span class="lead">The trick — </span>${b.trick}</div>
    <div class="detail">
      ${team?`<h4>Team (ace highlighted)</h4><div class="team">${team}</div>`:''}
      ${b.answers?`<h4>What answers it</h4><div class="answers">${b.answers}</div>`:''}
      ${catches?`<h4>Worth catching before this</h4><div class="chips">${catches}</div>`:''}
    </div></div>`;
}
function render(tab){
  activeTab=tab; save('tab',tab);
  const C=document.getElementById('content');
  document.getElementById('starterBar').style.display = tab==='rival'?'flex':'none';
  let html="";
  if(tab==='playbook'){
    html=`<div class="section-label">General principles</div><div class="tools">`+
      PLAYBOOK.map(p=>`<div class="tool"><h3>${p[0]}</h3><span>${p[1]}</span></div>`).join("")+`</div>`;
  } else if(tab==='johto'){
    html=`<div class="section-label">Johto · 8 gyms · tap a card</div>`+JOHTO.map(g=>bossCard(g,`GYM ${g.n}`)).join("");
  } else if(tab==='rival'){
    const L=RIVAL_LINE[starter];
    document.getElementById('starterNote').innerHTML=`&rarr; rival runs the <b style="color:var(--text)">${L.late}</b> line (${L.type})`;
    html=`<div class="note">Silver's team is fixed except his starter, which always type-beats yours. His spine: Sneasel, Golbat&rarr;Crobat, Magnemite&rarr;Magneton, Haunter&rarr;Gengar, Kadabra&rarr;Alakazam. A <b>Dark</b> move answers a lot of it.</div>`+
      RIVAL.map(r=>bossCard(Object.assign({},r,{team:resolveSlots(r.slots),type:'dark'}),`FIGHT ${r.n}`)).join("");
  } else if(tab==='e4'){
    html=`<div class="note">All at the Indigo Plateau once you have 8 Johto badges. Levels 40–50 — your first cap jump after Clair.</div>`+
      E4.map(b=>bossCard(b,b.n==='C'?'CHAMPION':`ELITE ${b.n.slice(1)}`)).join("");
  } else if(tab==='kanto'){
    html=`<div class="note"><b>Order is yours.</b> Kanto leaders have fixed teams (~Lv 49–60) but you tackle them in any order — so cap against <b>whichever you pick next</b>, not a fixed ladder. Surge is reachable first; <b>Blue</b> only appears once the other 7 Kanto badges are in.</div>`+
      KANTO.map(g=>bossCard(g,`GYM ${g.n}`)).join("");
  } else if(tab==='red'){
    html=`<div class="note">Mt. Silver, after all 16 badges. The true capstone — and the ultimate test of a tactics-first, no-overlevel run.</div>`+
      RED.map(b=>bossCard(b,'FINAL')).join("");
  } else if(tab==='rocket'){
    html=`<div class="note">Story gates, not optional. Rosters are grunt-heavy so they vary; the levels and the executive aces are what matter — flagged per card.</div>`+
      ROCKET.map(b=>bossCard(b,'ROCKET')).join("");
  } else if(tab==='legend'){
    html=`<div class="note">A different kind of prep: these are <b>catches</b>, not wins. The drill is always the same — chip to ~1 HP with <b>False Swipe</b>, land <b>sleep</b> (or paralysis), then throw Ultra/Dusk/Timer Balls. Save before each.</div>`+
      `<div class="section-label">Capture targets</div>`+
      LEGEND.map(l=>`<div class="card" style="--gc:var(--gold)" open-state="0">
        <button class="chead" aria-expanded="false">
          <div class="stamp"><span class="cap">Lv</span><span class="lv">${l.lv}</span></div>
          <div class="cmeta"><div class="cnum">${l.req2.toUpperCase()}</div><div class="cname">${l.name}</div>
          <div class="badges"><span class="loc">${l.loc} · needs ${l.req}</span></div></div>
          <span class="chev">&#9654;</span></button>
        <div class="detail"><div class="answers">${l.tip}</div></div></div>`).join("");
  }
  C.innerHTML=html; bindCards(); window.scrollTo({top:0,behavior:'auto'});
}
function bindCards(){
  document.querySelectorAll('.card').forEach(card=>{
    const btn=card.querySelector('.chead');
    btn.addEventListener('click',()=>{const open=card.getAttribute('open-state')==='1';
      card.setAttribute('open-state',open?'0':'1'); btn.setAttribute('aria-expanded',open?'false':'true');});
  });
}
const tabsEl=document.getElementById('tabs');
TABS.forEach((t,i)=>{
  const b=document.createElement('button');
  b.className='tab';b.textContent=t.label;b.setAttribute('role','tab');
  b.setAttribute('aria-selected',t.id===activeTab?'true':'false');
  b.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(x=>x.setAttribute('aria-selected','false'));
    b.setAttribute('aria-selected','true');render(t.id);});
  tabsEl.appendChild(b);
});
document.querySelectorAll('#starterSeg button').forEach(btn=>{
  btn.addEventListener('click',()=>{starter=btn.dataset.s; save('starter',starter);
    document.querySelectorAll('#starterSeg button').forEach(x=>x.setAttribute('aria-pressed','false'));
    btn.setAttribute('aria-pressed','true'); render('rival');});
});
document.getElementById('foot').innerHTML=`Gym, rival, Elite Four & Red teams verified from source (HeartGold first-battle data). Rocket gates summarised. Caps = each fight's ace level.`;
// Reflect the persisted starter on the segmented control, then restore the last tab.
document.querySelectorAll('#starterSeg button').forEach(x=>x.setAttribute('aria-pressed',x.dataset.s===starter?'true':'false'));
render(activeTab);

if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/heartgold-battle-prep/sw.js', { scope: '/heartgold-battle-prep/' }).catch(() => {});
  });
}
</script>
</body>
</html>
